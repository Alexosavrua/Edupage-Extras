{
  "name": "Edupage Extras",
  "description": "A Chromium extension that adds extra QoL features to Edupage.",
  "version": "0.0.1",
  "manifest_version": 3,
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "menu/menu.html",
    "default_icon": "images/placeholder_icon.png"
  },
  "content_scripts": [
    {
      "js": ["scripts/content.js"],
      "matches": ["https://*.edupage.org/*"]
    }
  ]
}